"use client"

import { useState, useEffect } from "react"
import { useRouter } from "next/navigation"
import { sendToTelegram } from "@/lib/send-telegram-bot"
import { motion, AnimatePresence } from "framer-motion"
import { toast } from "sonner"

const grades = ["1-sinf", "2-sinf", "3-sinf", "4-sinf", "5-sinf", "6-sinf", "7-sinf", "8-sinf", "9-sinf", "10-sinf", "11-sinf"]

export default function RegistrationForm() {
  const router = useRouter()
  const [formData, setFormData] = useState({
    firstname: "",
    lastname: "",
    fathername: "",
    mothername: "",
    phone: "",
    phone2: "",
    school: "",
    grade: "5-sinf",
  })
  const [isSubmitting, setIsSubmitting] = useState(false)
  const [errors, setErrors] = useState({})
  const [isMobile, setIsMobile] = useState(false)
  const [activeField, setActiveField] = useState(null)

  useEffect(() => {
    const checkMobile = () => {
      setIsMobile(window.innerWidth < 768)
    }

    checkMobile()
    window.addEventListener("resize", checkMobile)

    return () => {
      window.removeEventListener("resize", checkMobile)
    }
  }, [])

  // New phone number formatting function
  const formatPhoneNumber = (input) => {
    // Remove all non-digit characters
    const digitsOnly = input.replace(/\D/g, "")

    // Limit to 9 digits
    const trimmedDigits = digitsOnly.slice(0, 9)

    // Format phone number
    if (trimmedDigits.length <= 2) {
      return trimmedDigits
    } else if (trimmedDigits.length <= 5) {
      return `${trimmedDigits.slice(0, 2)} ${trimmedDigits.slice(2)}`
    } else if (trimmedDigits.length <= 7) {
      return `${trimmedDigits.slice(0, 2)} ${trimmedDigits.slice(2, 5)} ${trimmedDigits.slice(5)}`
    } else {
      return `${trimmedDigits.slice(0, 2)} ${trimmedDigits.slice(2, 5)} ${trimmedDigits.slice(5, 7)} ${trimmedDigits.slice(7)}`
    }
  }

  const handlePhoneChange = (e) => {
    const formattedPhone = formatPhoneNumber(e.target.value)

    setFormData((prev) => ({ ...prev, phone: formattedPhone }))

    // Clear error when user types
    if (errors.phone) {
      setErrors((prev) => {
        const newErrors = { ...prev }
        delete newErrors.phone
        return newErrors
      })
    }
  }

  const handleChange = (e) => {
    const { id, value } = e.target
    setFormData((prev) => ({ ...prev, [id]: value }))

    // Clear error when user types
    if (errors[id]) {
      setErrors((prev) => {
        const newErrors = { ...prev }
        delete newErrors[id]
        return newErrors
      })
    }
  }

  const handleSelectChange = (value) => {
    setFormData((prev) => ({ ...prev, course: value }))
  }

  const validateForm = () => {
    const newErrors = {}

    if (!formData.firstname.trim()) {
      newErrors.firstname = "Iltimos, ismingizni kiriting"
    }

    if (!formData.lastname.trim()) {
      newErrors.lastname = "Iltimos, familiyangizni kiriting"
    }

    if (!formData.fathername.trim()) {
      newErrors.fathername = "Iltimos, otangizning nomini kiriting"
    }

    if (!formData.mothername.trim()) {
      newErrors.mothername = "Iltimos, onangizning nomini kiriting"
    }

    if (!formData.school.trim()) {
      newErrors.school = "Iltimos, maktabingizning nomini kiriting"
    }

    if (!formData.phone.trim()) {
      newErrors.phone = "Iltimos, telefon raqamingizni kiriting"
    } else {
      const digitsOnly = formData.phone.replace(/\D/g, "")
      if (digitsOnly.length !== 9) {
        newErrors.phone = "Telefon raqami aniq 9 raqamdan iborat bo'lishi kerak"
      } else if (!/^(9[01234789]|88|33|71|90|93|94|95|97|98|99|55|77)/.test(digitsOnly)) {
        newErrors.phone = "Noto'g'ri telefon raqami kodi"
      }
    }

    if (formData.phone2.trim()) {
      const digitsOnly = formData.phone2.replace(/\D/g, "")
      if (digitsOnly.length !== 9) {
        newErrors.phone2 = "Telefon raqami aniq 9 raqamdan iborat bo'lishi kerak"
      } else if (!/^(9[01234789]|88|33|71|90|93|94|95|97|98|99|55|77)/.test(digitsOnly)) {
        newErrors.phone2 = "Noto'g'ri telefon raqami kodi"
      }
    }

    setErrors(newErrors)
    return Object.keys(newErrors).length === 0
  }

  const handleSubmit = async (e) => {
    e.preventDefault()

    if (!validateForm()) {
      return
    }

    setIsSubmitting(true)

    try {
      await sendToTelegram({
        ...formData,
        phone: "+998 " + formData.phone,
      })
      toast.success("O'quvchi ma'lumotlari muvaffaqiyatli yuborildi!")
      router.push("/success")
    } catch (error) {
      console.error("Xatolik yuz berdi:", error)
      toast.error("Ma'lumotlarni yuborishda xatolik yuz berdi. Iltimos, qayta urinib ko'ring.")
    } finally {
      setIsSubmitting(false)
    }
  }
  // Mobile step-by-step form
  if (isMobile) {
    return (
      <div className="min-h-[calc(100vh-2rem)] bg-gradient-to-b from-purple-100 via-blue-50 to-teal-50 rounded-xl shadow-lg overflow-hidden animate-fadeIn relative">
        {/* Top gradient accent bar */}
        <motion.div
          className="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-purple-600 via-blue-500 to-teal-500 z-0"
          initial={{ scaleX: 0 }}
          animate={{ scaleX: 1 }}
          transition={{ type: "spring", stiffness: 100, damping: 15 }}
        ></motion.div>

        <div className="relative z-10 p-6">
          {/* Header with logos */}
          <motion.div
            className="flex justify-around items-center mb-8 mt-2"
            initial={{ scale: 0 }}
            animate={{ scale: 1 }}
            transition={{ type: "spring", stiffness: 260, damping: 20, delay: 0.2 }}
          >
            <div className="w-16 h-16 flex items-center justify-center">
              <img src="/logo1.png" alt="Logo 1" className="w-full h-full object-contain" />
            </div>
            <div className="w-16 h-16 flex items-center justify-center">
              <img src="/logo2.png" alt="Logo 2" className="w-full h-full object-contain" />
            </div>
            <div className="w-16 h-16 flex items-center justify-center">
              <img src="/logo3.png" alt="Logo 3" className="w-full h-full object-contain" />
            </div>
          </motion.div>

          <motion.h2
            className="text-3xl font-black text-center mb-1 bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent tracking-tight"
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ delay: 0.3 }}
          >
            Yosh Bilimdonlar
          </motion.h2>

          <motion.p
            className="text-teal-600 text-center mb-8 text-xs font-bold uppercase tracking-widest"
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            transition={{ delay: 0.4 }}
          >
            Olimpiadasi Ro&apos;yxati
          </motion.p>

          <form onSubmit={handleSubmit} className="space-y-6">
            {/* Progress indicator */}
            <div className="flex justify-between mb-6 gap-1">
              {["firstname", "lastname", "fathername", "mothername", "school", "grade", "phone"].map((step, index) => (
                <motion.div
                  key={step}
                  className={`flex-1 h-2 rounded-full ${
                    activeField === step
                      ? "bg-gradient-to-r from-purple-500 to-blue-500"
                      : Object.keys(formData).indexOf(activeField || "") > index
                        ? "bg-teal-500"
                        : "bg-gray-300"
                  }`}
                  whileHover={{ scale: 1.1 }}
                  animate={
                    activeField === step
                      ? {
                          scale: [1, 1.1, 1],
                          transition: {
                            repeat: Number.POSITIVE_INFINITY,
                            duration: 1.5,
                          },
                        }
                      : {}
                  }
                ></motion.div>
              ))}
            </div>

            {/* Conditional rendering based on active field */}
            <AnimatePresence mode="wait">
              {(!activeField || activeField === "firstname") && (
                <motion.div
                  key="firstname"
                  className="bg-white p-6 rounded-2xl shadow-lg border border-purple-200"
                  initial={{ opacity: 0, x: -50 }}
                  animate={{ opacity: 1, x: 0 }}
                  exit={{ opacity: 0, x: 50 }}
                  transition={{ type: "spring", stiffness: 300, damping: 25 }}
                >
                  <label htmlFor="firstname" className="block font-bold text-purple-600 mb-2 text-lg">
                    Ismingiz
                  </label>
                  <input
                    id="firstname"
                    type="text"
                    placeholder="Ismingizni kiriting"
                    value={formData.firstname}
                    onChange={handleChange}
                    onFocus={() => setActiveField("firstname")}
                    className={`w-full px-4 py-3 text-lg border-2 rounded-lg bg-gray-50 text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition ${
                      errors.firstname ? "border-red-500" : "border-purple-200"
                    }`}
                  />
                  <AnimatePresence>
                    {errors.firstname && (
                      <motion.p
                        className="text-red-500 text-sm mt-2"
                        initial={{ opacity: 0, height: 0 }}
                        animate={{ opacity: 1, height: "auto" }}
                        exit={{ opacity: 0, height: 0 }}
                      >
                        {errors.firstname}
                      </motion.p>
                    )}
                  </AnimatePresence>

                  <motion.button
                    type="button"
                    onClick={() => {
                      if (!formData.firstname.trim()) {
                        setErrors((prev) => ({ ...prev, firstname: "Iltimos, ismingizni kiriting" }))
                        return
                      }
                      setActiveField("lastname")
                    }}
                    className="w-full bg-amber-500 hover:bg-amber-600 text-black font-bold py-3 px-4 rounded-lg transition mt-4 flex items-center justify-center"
                    whileHover={{ scale: 1.02 }}
                    whileTap={{ scale: 0.98 }}
                  >
                    Keyingi
                  </motion.button>
                </motion.div>
              )}

              {activeField === "lastname" && (
                <motion.div
                  key="lastname"
                  className="bg-white p-6 rounded-2xl shadow-lg border border-purple-200"
                  initial={{ opacity: 0, x: 50 }}
                  animate={{ opacity: 1, x: 0 }}
                  exit={{ opacity: 0, x: -50 }}
                  transition={{ type: "spring", stiffness: 300, damping: 25 }}
                >
                  <label htmlFor="lastname" className="block font-medium text-amber-300 mb-2 text-lg">
                    Familiyangiz
                  </label>
                  <input
                    id="lastname"
                    type="text"
                    placeholder="Familiyangizni kiriting"
                    value={formData.lastname}
                    onChange={handleChange}
                    className={`w-full px-4 py-3 text-lg border rounded-lg bg-zinc-800 text-white placeholder-zinc-500 focus:ring-2 focus:ring-amber-400 focus:border-amber-400 outline-none transition ${
                      errors.lastname ? "border-red-500" : "border-zinc-700"
                    }`}
                  />
                  <AnimatePresence>
                    {errors.lastname && (
                      <motion.p
                        className="text-red-500 text-sm mt-2"
                        initial={{ opacity: 0, height: 0 }}
                        animate={{ opacity: 1, height: "auto" }}
                        exit={{ opacity: 0, height: 0 }}
                      >
                        {errors.lastname}
                      </motion.p>
                    )}
                  </AnimatePresence>

                  <div className="flex gap-2 mt-4">
                    <motion.button
                      type="button"
                      onClick={() => setActiveField("firstname")}
                      className="w-1/3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold py-3 px-4 rounded-lg transition"
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                    >
                      Orqaga
                    </motion.button>
                    <motion.button
                      type="button"
                      onClick={() => {
                        if (!formData.lastname.trim()) {
                          setErrors((prev) => ({ ...prev, lastname: "Iltimos, familiyangizni kiriting" }))
                          return
                        }
                        setActiveField("fathername")
                      }}
                      className="w-2/3 bg-gradient-to-r from-purple-500 to-blue-500 hover:from-purple-600 hover:to-blue-600 text-white font-bold py-3 px-4 rounded-lg transition"
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                    >
                      Keyingi
                    </motion.button>
                  </div>
                </motion.div>
              )}

              {activeField === "fathername" && (
                <motion.div
                  key="fathername"
                  className="bg-white p-6 rounded-2xl shadow-lg border border-purple-200"
                  initial={{ opacity: 0, x: 50 }}
                  animate={{ opacity: 1, x: 0 }}
                  exit={{ opacity: 0, x: -50 }}
                  transition={{ type: "spring", stiffness: 300, damping: 25 }}
                >
                  <label htmlFor="fathername" className="block font-bold text-purple-600 mb-2 text-lg">
                    Otangizning ismi
                  </label>
                  <input
                    id="fathername"
                    type="text"
                    placeholder="Otangizning ismini kiriting"
                    value={formData.fathername}
                    onChange={handleChange}
                    className={`w-full px-4 py-3 text-lg border-2 rounded-lg bg-gray-50 text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition ${
                      errors.fathername ? "border-red-500" : "border-purple-200"
                    }`}
                  />
                  <AnimatePresence>
                    {errors.fathername && (
                      <motion.p
                        className="text-red-500 text-sm mt-2"
                        initial={{ opacity: 0, height: 0 }}
                        animate={{ opacity: 1, height: "auto" }}
                        exit={{ opacity: 0, height: 0 }}
                      >
                        {errors.fathername}
                      </motion.p>
                    )}
                  </AnimatePresence>

                  <div className="flex gap-2 mt-4">
                    <motion.button
                      type="button"
                      onClick={() => setActiveField("lastname")}
                      className="w-1/3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold py-3 px-4 rounded-lg transition"
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                    >
                      Orqaga
                    </motion.button>
                    <motion.button
                      type="button"
                      onClick={() => {
                        if (!formData.fathername.trim()) {
                          setErrors((prev) => ({ ...prev, fathername: "Iltimos, otangizning nomini kiriting" }))
                          return
                        }
                        setActiveField("mothername")
                      }}
                      className="w-2/3 bg-gradient-to-r from-purple-500 to-blue-500 hover:from-purple-600 hover:to-blue-600 text-white font-bold py-3 px-4 rounded-lg transition"
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                    >
                      Keyingi
                    </motion.button>
                  </div>
                </motion.div>
              )}

              {activeField === "mothername" && (
                <motion.div
                  key="mothername"
                  className="bg-white p-6 rounded-2xl shadow-lg border border-purple-200"
                  initial={{ opacity: 0, x: 50 }}
                  animate={{ opacity: 1, x: 0 }}
                  exit={{ opacity: 0, x: -50 }}
                  transition={{ type: "spring", stiffness: 300, damping: 25 }}
                >
                  <label htmlFor="mothername" className="block font-medium text-gray-700 mb-2 text-lg">
                    Onangizning ismi
                  </label>
                  <input
                    id="mothername"
                    type="text"
                    placeholder="Onangizning ismini kiriting"
                    value={formData.mothername}
                    onChange={handleChange}
                    className={`w-full px-4 py-3 text-lg border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition ${
                      errors.mothername ? "border-red-500" : "border-gray-300"
                    }`}
                  />
                  <AnimatePresence>
                    {errors.mothername && (
                      <motion.p
                        className="text-red-500 text-sm mt-2"
                        initial={{ opacity: 0, height: 0 }}
                        animate={{ opacity: 1, height: "auto" }}
                        exit={{ opacity: 0, height: 0 }}
                      >
                        {errors.mothername}
                      </motion.p>
                    )}
                  </AnimatePresence>

                  <div className="flex gap-2 mt-4">
                    <motion.button
                      type="button"
                      onClick={() => setActiveField("fathername")}
                      className="w-1/3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold py-3 px-4 rounded-lg transition"
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                    >
                      Orqaga
                    </motion.button>
                    <motion.button
                      type="button"
                      onClick={() => {
                        if (!formData.mothername.trim()) {
                          setErrors((prev) => ({ ...prev, mothername: "Iltimos, onangizning nomini kiriting" }))
                          return
                        }
                        setActiveField("school")
                      }}
                      className="w-2/3 bg-gradient-to-r from-purple-500 to-blue-500 hover:from-purple-600 hover:to-blue-600 text-white font-bold py-3 px-4 rounded-lg transition"
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                    >
                      Keyingi
                    </motion.button>
                  </div>
                </motion.div>
              )}

              {activeField === "school" && (
                <motion.div
                  key="school"
                  className="bg-white p-6 rounded-2xl shadow-lg border border-purple-200"
                  initial={{ opacity: 0, x: 50 }}
                  animate={{ opacity: 1, x: 0 }}
                  exit={{ opacity: 0, x: -50 }}
                  transition={{ type: "spring", stiffness: 300, damping: 25 }}
                >
                  <label htmlFor="school" className="block font-medium text-gray-700 mb-2 text-lg">
                    Maktabingizning nomi
                  </label>
                  <input
                    id="school"
                    type="text"
                    placeholder="Maktabingizning nomini kiriting"
                    value={formData.school}
                    onChange={handleChange}
                    className={`w-full px-4 py-3 text-lg border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition ${
                      errors.school ? "border-red-500" : "border-gray-300"
                    }`}
                  />
                  <AnimatePresence>
                    {errors.school && (
                      <motion.p
                        className="text-red-500 text-sm mt-2"
                        initial={{ opacity: 0, height: 0 }}
                        animate={{ opacity: 1, height: "auto" }}
                        exit={{ opacity: 0, height: 0 }}
                      >
                        {errors.school}
                      </motion.p>
                    )}
                  </AnimatePresence>

                  <div className="flex gap-2 mt-4">
                    <motion.button
                      type="button"
                      onClick={() => setActiveField("mothername")}
                      className="w-1/3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold py-3 px-4 rounded-lg transition"
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                    >
                      Orqaga
                    </motion.button>
                    <motion.button
                      type="button"
                      onClick={() => {
                        if (!formData.school.trim()) {
                          setErrors((prev) => ({ ...prev, school: "Iltimos, maktabingizning nomini kiriting" }))
                          return
                        }
                        setActiveField("grade")
                      }}
                      className="w-2/3 bg-gradient-to-r from-purple-500 to-blue-500 hover:from-purple-600 hover:to-blue-600 text-white font-bold py-3 px-4 rounded-lg transition"
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                    >
                      Keyingi
                    </motion.button>
                  </div>
                </motion.div>
              )}

              {activeField === "grade" && (
                <motion.div
                  key="grade"
                  className="bg-white p-6 rounded-2xl shadow-lg border border-purple-200"
                  initial={{ opacity: 0, x: 50 }}
                  animate={{ opacity: 1, x: 0 }}
                  exit={{ opacity: 0, x: -50 }}
                  transition={{ type: "spring", stiffness: 300, damping: 25 }}
                >
                  <label htmlFor="grade" className="block font-medium text-gray-700 mb-2 text-lg">
                    Sinfi
                  </label>
                  <select
                    id="grade"
                    value={formData.grade}
                    onChange={handleChange}
                    className="w-full px-4 py-3 text-lg border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition bg-white"
                  >
                    {grades.map((grade) => (
                      <option key={grade} value={grade}>
                        {grade}
                      </option>
                    ))}
                  </select>

                  <div className="flex gap-2 mt-4">
                    <motion.button
                      type="button"
                      onClick={() => setActiveField("school")}
                      className="w-1/3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold py-3 px-4 rounded-lg transition"
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                    >
                      Orqaga
                    </motion.button>
                    <motion.button
                      type="button"
                      onClick={() => setActiveField("phone")}
                      className="w-2/3 bg-gradient-to-r from-purple-500 to-blue-500 hover:from-purple-600 hover:to-blue-600 text-white font-bold py-3 px-4 rounded-lg transition"
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                    >
                      Keyingi
                    </motion.button>
                  </div>
                </motion.div>
              )}

              {activeField === "lastname" && (
                <motion.div
                  key="lastname"
                  className="bg-white p-6 rounded-2xl shadow-lg border border-purple-200"
                  initial={{ opacity: 0, x: 50 }}
                  animate={{ opacity: 1, x: 0 }}
                  exit={{ opacity: 0, x: -50 }}
                  transition={{ type: "spring", stiffness: 300, damping: 25 }}
                >
                  <label htmlFor="lastname" className="block font-medium text-amber-300 mb-2 text-lg">
                    Familiyangiz
                  </label>
                  <input
                    id="lastname"
                    type="text"
                    placeholder="Familiyangizni kiriting"
                    value={formData.lastname}
                    onChange={handleChange}
                    className={`w-full px-4 py-3 text-lg border rounded-lg bg-zinc-800 text-white placeholder-zinc-500 focus:ring-2 focus:ring-amber-400 focus:border-amber-400 outline-none transition ${
                      errors.lastname ? "border-red-500" : "border-zinc-700"
                    }`}
                  />
                  <AnimatePresence>
                    {errors.lastname && (
                      <motion.p
                        className="text-red-500 text-sm mt-2"
                        initial={{ opacity: 0, height: 0 }}
                        animate={{ opacity: 1, height: "auto" }}
                        exit={{ opacity: 0, height: 0 }}
                      >
                        {errors.lastname}
                      </motion.p>
                    )}
                  </AnimatePresence>

                  <div className="flex gap-2 mt-4">
                    <motion.button
                      type="button"
                      onClick={() => setActiveField("firstname")}
                      className="w-1/3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold py-3 px-4 rounded-lg transition"
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                    >
                      Orqaga
                    </motion.button>
                    <motion.button
                      type="button"
                      onClick={() => {
                        if (!formData.lastname.trim()) {
                          setErrors((prev) => ({ ...prev, lastname: "Iltimos, familiyangizni kiriting" }))
                          return
                        }
                        setActiveField("age")
                      }}
                      className="w-2/3 bg-gradient-to-r from-purple-500 to-blue-500 hover:from-purple-600 hover:to-blue-600 text-white font-bold py-3 px-4 rounded-lg transition"
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                    >
                      Keyingi
                    </motion.button>
                  </div>
                </motion.div>
              )}



              {activeField === "phone" && (
                <motion.div
                  key="phone"
                  className="bg-white p-6 rounded-2xl shadow-lg border border-purple-200"
                  initial={{ opacity: 0, x: 50 }}
                  animate={{ opacity: 1, x: 0 }}
                  exit={{ opacity: 0, x: -50 }}
                  transition={{ type: "spring", stiffness: 300, damping: 25 }}
                >
                  <label htmlFor="phone" className="block font-medium text-gray-700 mb-2 text-lg">
                    Telefon raqami (bosh)
                  </label>
                  <div className="relative mb-4">
                    <span className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-lg">+998</span>
                    <input
                      id="phone"
                      type="tel"
                      placeholder="90 123 45 67"
                      value={formData.phone}
                      onChange={handlePhoneChange}
                      className={`w-full px-4 py-3 text-lg border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition pl-16 ${errors.phone ? "border-red-500" : "border-gray-300"}`}
                    />
                  </div>
                  <AnimatePresence>
                    {errors.phone && (
                      <motion.p
                        className="text-red-500 text-sm mt-2"
                        initial={{ opacity: 0, height: 0 }}
                        animate={{ opacity: 1, height: "auto" }}
                        exit={{ opacity: 0, height: 0 }}
                      >
                        {errors.phone}
                      </motion.p>
                    )}
                  </AnimatePresence>

                  <label htmlFor="phone2" className="block font-medium text-gray-700 mb-2 text-lg mt-4">
                    Telefon raqami (ikkinchi)
                  </label>
                  <div className="relative">
                    <span className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-lg">+998</span>
                    <input
                      id="phone2"
                      type="tel"
                      placeholder="90 123 45 67"
                      value={formData.phone2}
                      onChange={(e) => {
                        const formattedPhone = formatPhoneNumber(e.target.value)
                        setFormData((prev) => ({ ...prev, phone2: formattedPhone }))
                        if (errors.phone2) {
                          setErrors((prev) => {
                            const newErrors = { ...prev }
                            delete newErrors.phone2
                            return newErrors
                          })
                        }
                      }}
                      className={`w-full px-4 py-3 text-lg border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition pl-16 ${errors.phone2 ? "border-red-500" : "border-gray-300"}`}
                    />
                  </div>
                  <p className="text-xs text-gray-500 mt-1">Ixtiyoriy</p>
                  <AnimatePresence>
                    {errors.phone2 && (
                      <motion.p
                        className="text-red-500 text-sm mt-2"
                        initial={{ opacity: 0, height: 0 }}
                        animate={{ opacity: 1, height: "auto" }}
                        exit={{ opacity: 0, height: 0 }}
                      >
                        {errors.phone2}
                      </motion.p>
                    )}
                  </AnimatePresence>

                  <div className="flex gap-2 mt-4">
                    <motion.button
                      type="button"
                      onClick={() => setActiveField("grade")}
                      className="w-1/3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold py-3 px-4 rounded-lg transition"
                      whileHover={{ scale: 1.02 }}
                      whileTap={{ scale: 0.98 }}
                    >
                      Orqaga
                    </motion.button>
                    <motion.button
                      type="submit"
                      className="w-2/3 bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 px-4 rounded-lg transition flex items-center justify-center gap-2 disabled:bg-blue-300 disabled:cursor-not-allowed"
                      disabled={isSubmitting}
                      onClick={() => {
                        const digitsOnly = formData.phone.replace(/\D/g, "")
                        if (digitsOnly.length !== 9) {
                          setErrors((prev) => ({
                            ...prev,
                            phone: "Telefon raqami aniq 9 raqamdan iborat bo'lishi kerak",
                          }))
                          return
                        }
                        handleSubmit({preventDefault: () => {}})
                      }}
                      whileHover={{ scale: isSubmitting ? 1 : 1.02 }}
                      whileTap={{ scale: isSubmitting ? 1 : 0.98 }}
                    >
                      {isSubmitting ? (
                        <>
                          <svg
                            className="animate-spin h-5 w-5 text-white"
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                          >
                            <circle
                              className="opacity-25"
                              cx="12"
                              cy="12"
                              r="10"
                              stroke="currentColor"
                              strokeWidth="4"
                            ></circle>
                            <path
                              className="opacity-75"
                              fill="currentColor"
                              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                            ></path>
                          </svg>
                          Yuborilmoqda...
                        </>
                      ) : (
                        "Yuborish"
                      )}
                    </motion.button>
                  </div>
                </motion.div>
              )}
            </AnimatePresence>
          </form>
        </div>
      </div>
    )
  }

  // Desktop version with side-by-side layout
  return (
    <motion.div
      className="bg-white rounded-2xl shadow-2xl overflow-hidden flex flex-col md:flex-row border border-purple-200"
      initial={{ opacity: 0, y: 20 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.5 }}
    >
      {/* Left side - Info */}
      <motion.div
        className="bg-gradient-to-br from-purple-600 via-blue-500 to-teal-500 p-8 text-white md:w-2/5 flex flex-col justify-center items-center border-r border-purple-400"
        initial={{ x: -50, opacity: 0 }}
        animate={{ x: 0, opacity: 1 }}
        transition={{ delay: 0.2, duration: 0.5 }}
      >
        {/* Three logos */}
        <motion.div
          className="flex justify-around items-center gap-4 w-full mb-8"
          initial={{ scale: 0 }}
          animate={{ scale: 1 }}
          transition={{ type: "spring", stiffness: 260, damping: 20, delay: 0.5 }}
        >
          <div className="w-16 h-16 flex items-center justify-center bg-white/10 rounded-full p-2">
            <img src="/logo1.png" alt="Logo 1" className="w-full h-full object-contain" />
          </div>
          <div className="w-16 h-16 flex items-center justify-center bg-white/10 rounded-full p-2">
            <img src="/logo2.png" alt="Logo 2" className="w-full h-full object-contain" />
          </div>
          <div className="w-16 h-16 flex items-center justify-center bg-white/10 rounded-full p-2">
            <img src="/logo3.png" alt="Logo 3" className="w-full h-full object-contain" />
          </div>
        </motion.div>

        <motion.h2
          className="text-3xl font-black text-center mb-2 tracking-tight text-white"
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          transition={{ delay: 0.6 }}
        >
          Yosh Bilimdonlar
        </motion.h2>

        <motion.p
          className="text-blue-100 text-center mb-6 text-xs font-bold uppercase tracking-widest"
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          transition={{ delay: 0.7 }}
        >
          Olimpiadasi Ro&apos;yxati
        </motion.p>

        <motion.div
          className="bg-white/15 p-4 rounded-lg w-full border border-white/30 backdrop-blur-sm"
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.8 }}
          whileHover={{ scale: 1.02 }}
        >
          <h3 className="font-bold text-lg mb-2 text-white">Ro&apos;yxatni to&apos;ldirishda:</h3>
          <ul className="list-disc list-inside space-y-1 text-blue-100 text-sm">
            <motion.li initial={{ opacity: 0, x: -10 }} animate={{ opacity: 1, x: 0 }} transition={{ delay: 0.9 }}>
              To&apos;liq ism va familiya
            </motion.li>
            <motion.li initial={{ opacity: 0, x: -10 }} animate={{ opacity: 1, x: 0 }} transition={{ delay: 1.0 }}>
              Ota-ona ismlari
            </motion.li>
            <motion.li initial={{ opacity: 0, x: -10 }} animate={{ opacity: 1, x: 0 }} transition={{ delay: 1.1 }}>
              Maktaba va sinfi
            </motion.li>
            <motion.li initial={{ opacity: 0, x: -10 }} animate={{ opacity: 1, x: 0 }} transition={{ delay: 1.2 }}>
              Telefon raqamlari
            </motion.li>
          </ul>
        </motion.div>
      </motion.div>

      {/* Right side - Form */}
      <motion.div
        className="p-8 md:w-3/5"
        initial={{ x: 50, opacity: 0 }}
        animate={{ x: 0, opacity: 1 }}
        transition={{ delay: 0.3, duration: 0.5 }}
      >
        <motion.h3
          className="text-xl font-bold text-gray-800 mb-6"
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          transition={{ delay: 0.4 }}
        >
          Ro'yxatdan o'tish
        </motion.h3>

        <form onSubmit={handleSubmit} className="space-y-4">
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <motion.div
              className="space-y-2"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 0.5 }}
            >
              <label htmlFor="firstname" className="block font-bold text-purple-600">
                Ismi
              </label>
              <input
                id="firstname"
                type="text"
                placeholder="Ismingizni kiriting"
                value={formData.firstname}
                onChange={handleChange}
                className={`w-full px-4 py-2 border-2 rounded-lg bg-gray-50 text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition ${
                  errors.firstname ? "border-red-500" : "border-purple-200"
                }`}
              />
              <AnimatePresence>
                {errors.firstname && (
                  <motion.p
                    className="text-red-500 text-sm"
                    initial={{ opacity: 0, height: 0 }}
                    animate={{ opacity: 1, height: "auto" }}
                    exit={{ opacity: 0, height: 0 }}
                  >
                    {errors.firstname}
                  </motion.p>
                )}
              </AnimatePresence>
            </motion.div>

            <motion.div
              className="space-y-2"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 0.6 }}
            >
              <label htmlFor="lastname" className="block font-medium text-gray-700">
                Familiyasi
              </label>
              <input
                id="lastname"
                type="text"
                placeholder="Familiyangizni kiriting"
                value={formData.lastname}
                onChange={handleChange}
                className={`w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition ${
                  errors.lastname ? "border-red-500" : "border-gray-300"
                }`}
              />
              <AnimatePresence>
                {errors.lastname && (
                  <motion.p
                    className="text-red-500 text-sm"
                    initial={{ opacity: 0, height: 0 }}
                    animate={{ opacity: 1, height: "auto" }}
                    exit={{ opacity: 0, height: 0 }}
                  >
                    {errors.lastname}
                  </motion.p>
                )}
              </AnimatePresence>
            </motion.div>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <motion.div
              className="space-y-2"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 0.7 }}
            >
              <label htmlFor="fathername" className="block font-medium text-gray-700">
                Otasining ismi
              </label>
              <input
                id="fathername"
                type="text"
                placeholder="Otangizning ismini kiriting"
                value={formData.fathername}
                onChange={handleChange}
                className={`w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition ${
                  errors.fathername ? "border-red-500" : "border-gray-300"
                }`}
              />
              <AnimatePresence>
                {errors.fathername && (
                  <motion.p
                    className="text-red-500 text-sm"
                    initial={{ opacity: 0, height: 0 }}
                    animate={{ opacity: 1, height: "auto" }}
                    exit={{ opacity: 0, height: 0 }}
                  >
                    {errors.fathername}
                  </motion.p>
                )}
              </AnimatePresence>
            </motion.div>

            <motion.div
              className="space-y-2"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 0.8 }}
            >
              <label htmlFor="mothername" className="block font-medium text-gray-700">
                Onasining ismi
              </label>
              <input
                id="mothername"
                type="text"
                placeholder="Onangizning ismini kiriting"
                value={formData.mothername}
                onChange={handleChange}
                className={`w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition ${
                  errors.mothername ? "border-red-500" : "border-gray-300"
                }`}
              />
              <AnimatePresence>
                {errors.mothername && (
                  <motion.p
                    className="text-red-500 text-sm"
                    initial={{ opacity: 0, height: 0 }}
                    animate={{ opacity: 1, height: "auto" }}
                    exit={{ opacity: 0, height: 0 }}
                  >
                    {errors.mothername}
                  </motion.p>
                )}
              </AnimatePresence>
            </motion.div>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <motion.div
              className="space-y-2"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 0.9 }}
            >
              <label htmlFor="school" className="block font-medium text-gray-700">
                Maktabaning nomi
              </label>
              <input
                id="school"
                type="text"
                placeholder="Maktabaning nomini kiriting"
                value={formData.school}
                onChange={handleChange}
                className={`w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition ${
                  errors.school ? "border-red-500" : "border-gray-300"
                }`}
              />
              <AnimatePresence>
                {errors.school && (
                  <motion.p
                    className="text-red-500 text-sm"
                    initial={{ opacity: 0, height: 0 }}
                    animate={{ opacity: 1, height: "auto" }}
                    exit={{ opacity: 0, height: 0 }}
                  >
                    {errors.school}
                  </motion.p>
                )}
              </AnimatePresence>
            </motion.div>

            <motion.div
              className="space-y-2"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 1.0 }}
            >
              <label htmlFor="grade" className="block font-medium text-gray-700">
                Sinfi
              </label>
              <select
                id="grade"
                value={formData.grade}
                onChange={handleChange}
                className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition bg-white"
              >
                {grades.map((grade) => (
                  <option key={grade} value={grade}>
                    {grade}
                  </option>
                ))}
              </select>
            </motion.div>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <motion.div
              className="space-y-2"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 1.1 }}
            >
              <label htmlFor="phone" className="block font-medium text-gray-700">
                Telefon raqami
              </label>
              <div className="relative">
                <span className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500">+998</span>
                <input
                  id="phone"
                  type="tel"
                  placeholder="90 123 45 67"
                  value={formData.phone}
                  onChange={handlePhoneChange}
                  className={`w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition pl-14 ${errors.phone ? "border-red-500" : "border-gray-300"}`}
                />
              </div>
              <AnimatePresence>
                {errors.phone && (
                  <motion.p
                    className="text-red-500 text-sm"
                    initial={{ opacity: 0, height: 0 }}
                    animate={{ opacity: 1, height: "auto" }}
                    exit={{ opacity: 0, height: 0 }}
                  >
                    {errors.phone}
                  </motion.p>
                )}
              </AnimatePresence>
            </motion.div>

            <motion.div
              className="space-y-2"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 1.2 }}
            >
              <label htmlFor="phone2" className="block font-medium text-gray-700">
                Telefon raqami (2)
              </label>
              <div className="relative">
                <span className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500">+998</span>
                <input
                  id="phone2"
                  type="tel"
                  placeholder="90 123 45 67"
                  value={formData.phone2}
                  onChange={(e) => {
                    const formattedPhone = formatPhoneNumber(e.target.value)
                    setFormData((prev) => ({ ...prev, phone2: formattedPhone }))
                    if (errors.phone2) {
                      setErrors((prev) => {
                        const newErrors = { ...prev }
                        delete newErrors.phone2
                        return newErrors
                      })
                    }
                  }}
                  className={`w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition pl-14 ${errors.phone2 ? "border-red-500" : "border-gray-300"}`}
                />
              </div>
              <p className="text-xs text-gray-500 mt-1">Ixtiyoriy</p>
              <AnimatePresence>
                {errors.phone2 && (
                  <motion.p
                    className="text-red-500 text-sm"
                    initial={{ opacity: 0, height: 0 }}
                    animate={{ opacity: 1, height: "auto" }}
                    exit={{ opacity: 0, height: 0 }}
                  >
                    {errors.phone2}
                  </motion.p>
                )}
              </AnimatePresence>
            </motion.div>
          </div>

          <motion.button
            type="submit"
            className="w-full bg-gradient-to-r from-purple-500 to-blue-500 hover:from-purple-600 hover:to-blue-600 text-white font-bold py-2.5 px-4 rounded-lg transition flex items-center justify-center gap-2 disabled:from-purple-400 disabled:to-blue-400 disabled:cursor-not-allowed mt-6"
            disabled={isSubmitting}
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ delay: 1.3 }}
            whileHover={{ scale: isSubmitting ? 1 : 1.02 }}
            whileTap={{ scale: isSubmitting ? 1 : 0.98 }}
          >
            {isSubmitting ? (
              <>
                <svg
                  className="animate-spin h-5 w-5 text-white"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                >
                  <circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4"></circle>
                  <path
                    className="opacity-75"
                    fill="currentColor"
                    d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                  ></path>
                </svg>
                Yuborilmoqda...
              </>
            ) : (
              "Yuborish"
            )}
          </motion.button>
        </form>
      </motion.div>
    </motion.div>
  )
}

